{
  "name": "borrowing-calculator-tests",
  "version": "1.0.0",
  "description": "Automated tests for the borrowing power calculator using Cucumber and Playwright",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:html": "cucumber-js --format json:reports/results.json && node scripts/generate-html-report.js",
    "test:headed": "HEADED=true cucumber-js",
    "test:debug": "cucumber-js --format progress-bar",
    "test:ci": "cucumber-js --format json:reports/results.json --format message:reports/results.ndjson && node scripts/generate-html-report.js"
  },
  "keywords": [
    "automation",
    "testing",
    "cucumber",
    "playwright",
    "bdd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@playwright/test": "^1.45.0",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "html-reporter": "^1.0.0"
  }
}
