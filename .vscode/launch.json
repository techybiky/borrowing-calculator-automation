{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Cucumber Tests",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "args": [
                "cucumber-js"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}